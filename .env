# Anthropic API Key (server-side only, never exposed to the browser)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override the assistant's system prompt directly (takes precedence
# over SYSTEM_PROMPT_CONFIG_FILE and the default config/data/assistant.config.json)
# SYSTEM_PROMPT=

# Optional: path to a JSON file matching the AssistantConfig shape
# ({ systemPrompt: string; faqs?: Record<string, string> }) to use instead of
# the default config/data/assistant.config.json
# SYSTEM_PROMPT_CONFIG_FILE=
